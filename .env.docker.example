# TradeClaw Docker Configuration
# Copy to .env: cp .env.docker.example .env

# ---------------------------------------------------------------------------
# Database (REQUIRED)
# ---------------------------------------------------------------------------
DB_NAME=tradeclaw
DB_USER=tradeclaw
DB_PASSWORD=changeme              # REQUIRED — generate: openssl rand -hex 16

# ---------------------------------------------------------------------------
# App (REQUIRED)
# ---------------------------------------------------------------------------
APP_PORT=3000
APP_URL=http://localhost:3000
USER_SESSION_SECRET=changeme      # REQUIRED (web app) — generate: openssl rand -hex 32
AUTH_SECRET=changeme              # REQUIRED (ws-server) — generate: openssl rand -hex 32

# ---------------------------------------------------------------------------
# Scanner (optional — defaults shown)
# ---------------------------------------------------------------------------
# SCAN_INTERVAL=60                # seconds between scans
# SCAN_INSTRUMENTS=all            # or comma-separated: BTCUSD,ETHUSD,XAUUSD

# ---------------------------------------------------------------------------
# Telegram Alerts (optional)
# ---------------------------------------------------------------------------
# TELEGRAM_BOT_TOKEN=
# TELEGRAM_FREE_CHANNEL_ID=

# ---------------------------------------------------------------------------
# Stripe Payments (optional)
# ---------------------------------------------------------------------------
# STRIPE_SECRET_KEY=
# STRIPE_PUBLISHABLE_KEY=
# STRIPE_WEBHOOK_SECRET=
