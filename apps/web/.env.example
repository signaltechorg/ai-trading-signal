# TradeClaw — Environment Variables
# Copy this file to .env.local and fill in your values.

# ---------------------------------------------------------------------------
# App
# ---------------------------------------------------------------------------
NEXT_PUBLIC_BASE_URL=https://tradeclaw.win

# Admin secret for protecting sensitive API endpoints (plugins, keys, import, webhooks)
# Generate with: openssl rand -hex 32
ADMIN_SECRET=

# Comma-separated emails granted admin dashboard access (matched against the
# Google sign-in email). Defaults to naimkatiman@gmail.com when unset so a
# fresh deploy is usable by the project owner.
ADMIN_EMAILS=

# Comma-separated emails granted Pro tier without an active Stripe subscription.
# For owner / team / demo accounts. Defaults to naimkatiman92@gmail.com.
PRO_EMAILS=

# Set to "true" to show the demo banner and enable feature hints for first-time visitors
NEXT_PUBLIC_DEMO_MODE=false

# ---------------------------------------------------------------------------
# Google OAuth (sign-in)
# ---------------------------------------------------------------------------
# Authorized redirect URI in Google Cloud Console must be:
#   https://<your-domain>/api/auth/google/callback
# (and http://localhost:3000/api/auth/google/callback for dev)
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=

# ---------------------------------------------------------------------------
# GitHub OAuth (sign-in)
# ---------------------------------------------------------------------------
# Create at https://github.com/settings/developers (OAuth Apps).
# Authorization callback URL must be:
#   https://<your-domain>/api/auth/github/callback
# (and http://localhost:3000/api/auth/github/callback for dev)
GITHUB_OAUTH_CLIENT_ID=
GITHUB_OAUTH_CLIENT_SECRET=

# Override the OAuth redirect host for both providers.
# Defaults to NEXT_PUBLIC_BASE_URL, then request origin.
OAUTH_REDIRECT_BASE_URL=

# Secret used to sign user session cookies (HMAC-SHA256). At least 16 chars.
# Generate with: openssl rand -hex 32
USER_SESSION_SECRET=

# ---------------------------------------------------------------------------
# Stripe
# ---------------------------------------------------------------------------
STRIPE_SECRET_KEY=sk_live_...
STRIPE_PUBLISHABLE_KEY=pk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...

# TradingView webhook — shared secret required on POST /api/tradingview/webhook
# Send via X-Webhook-Secret header or { "secret": "..." } in JSON body
TRADINGVIEW_WEBHOOK_SECRET=

# Price IDs — create these in your Stripe Dashboard
# Only Pro is sold via Stripe today. Elite is granted manually (no price ID).
STRIPE_PRO_MONTHLY_PRICE_ID=price_...
STRIPE_PRO_ANNUAL_PRICE_ID=price_...

# Public price IDs used by the pricing page (safe to expose to browser)
NEXT_PUBLIC_STRIPE_PRO_MONTHLY_PRICE_ID=price_...
NEXT_PUBLIC_STRIPE_PRO_ANNUAL_PRICE_ID=price_...

# ---------------------------------------------------------------------------
# Resend (transactional email)
# ---------------------------------------------------------------------------
# Used for the alert-channel signal emails AND the magic-link signin fallback.
# Sign up at https://resend.com, verify your domain, and create an API key.
# RESEND_FROM_EMAIL must be a verified sender on your Resend domain.
RESEND_API_KEY=re_...
RESEND_FROM_EMAIL=TradeClaw <signals@tradeclaw.win>

# ---------------------------------------------------------------------------
# Telegram
# ---------------------------------------------------------------------------
TELEGRAM_BOT_TOKEN=...
NEXT_PUBLIC_TELEGRAM_BOT_USERNAME=tradeclawbot

# Required for inbound /api/telegram webhook auth. Pass the same value to
# Telegram via setWebhook { secret_token: "..." }; Telegram echoes it back
# as the X-Telegram-Bot-Api-Secret-Token request header. The route compares
# constant-time and rejects unauthenticated POSTs (401).
# Generate with: openssl rand -hex 32
TELEGRAM_WEBHOOK_SECRET=

# Channel / group IDs (use negative numbers for groups, e.g. -1001234567890)
TELEGRAM_FREE_CHANNEL_ID=-100...

# Daily digest auto-poster channel (username like @your_channel or numeric -100123456789)
TELEGRAM_CHANNEL_ID=@your_channel_or_-100123456789
TELEGRAM_PRO_GROUP_ID=-100...
TELEGRAM_ELITE_GROUP_ID=-100...

# ---------------------------------------------------------------------------
# Database
# ---------------------------------------------------------------------------
DATABASE_URL=postgresql://user:password@host:5432/tradeclaw

# ---------------------------------------------------------------------------
# Redis (optional — used for API rate limiting on Elite tier)
# ---------------------------------------------------------------------------
UPSTASH_REDIS_REST_URL=https://...
UPSTASH_REDIS_REST_TOKEN=...

# ---------------------------------------------------------------------------
# Market Data API Keys (all optional — free tiers, keyless fallbacks exist)
# ---------------------------------------------------------------------------
# Finnhub — US stock quotes, 60 req/min free → https://finnhub.io/
FINNHUB_API_KEY=
# Twelve Data — multi-asset OHLCV, 800 req/day free → https://twelvedata.com/
TWELVE_DATA_API_KEY=
# Financial Modeling Prep — fundamentals, 250 req/day free → https://financialmodelingprep.com/
FMP_API_KEY=
# FRED — US economic data, 120 req/min free → https://fred.stlouisfed.org/
FRED_API_KEY=
# CryptoCompare — deep crypto history, 100k calls/month free → https://min-api.cryptocompare.com/
CRYPTOCOMPARE_API_KEY=
# OANDA — forex & metals OHLCV, free practice account → https://developer.oanda.com/
OANDA_API_TOKEN=
OANDA_ACCOUNT_ID=
# Set to "live" for real trading account (default: practice)
# OANDA_API_ENV=live

# ---------------------------------------------------------------------------
# EarningsEdge — AI Earnings Call Analyzer
# ---------------------------------------------------------------------------
# OpenRouter API key for Gemini AI analysis
OPENROUTER_API_KEY=sk-or-v1-...

# Railway PostgreSQL for EarningsEdge
# Create a free project at https://supabase.com
EE_DATABASE_URL=postgresql://earningsedge:password@railway.internal:5432/earningsedge



# Stripe (can reuse TradeClaw keys or create separate EarningsEdge products)
# Create products in Stripe Dashboard: $29/month Basic, $49/month Pro
EARNINGSEDGE_STRIPE_SECRET_KEY=sk_live_...
EE_STRIPE_BASIC_MONTHLY_PRICE_ID=price_...
EE_STRIPE_PRO_MONTHLY_PRICE_ID=price_...
EE_STRIPE_WEBHOOK_SECRET=whsec_...

# ---------------------------------------------------------------------------
# Twilio (SMS Alerts)
# ---------------------------------------------------------------------------
TWILIO_ACCOUNT_SID=AC...
TWILIO_AUTH_TOKEN=...
TWILIO_FROM_NUMBER=+1234567890

# ---------------------------------------------------------------------------
# Supabase (optional — Postgres-backed storage instead of JSON files)
# ---------------------------------------------------------------------------
# NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
# NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOi...
# SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOi...
