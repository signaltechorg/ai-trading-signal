{
  "manifest_version": 3,
  "name": "TradeClaw Signal Badge",
  "version": "0.1.0",
  "description": "Live BTC, ETH, and XAU signal badges from TradeClaw for your browser toolbar.",
  "action": {
    "default_title": "TradeClaw Signal Badge",
    "default_popup": "popup.html"
  },
  "options_page": "options.html",
  "permissions": ["permissions", "storage"],
  "optional_host_permissions": ["<all_urls>"],
  "host_permissions": [
    "https://tradeclaw.win/*",
    "http://localhost:3000/*",
    "http://127.0.0.1:3000/*"
  ]
}
