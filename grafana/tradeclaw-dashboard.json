          "mappings": [
            { "options": { "-1": { "color": "red", "index": 0, "text": "SELL" } }, "type": "value" },
            { "options": { "0": { "color": "yellow", "index": 1, "text": "HOLD" } }, "type": "value" },
            { "options": { "1": { "color": "green", "index": 2, "text": "BUY" } }, "type": "value" }
          ],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "yellow", "value": -0.5 },
              { "color": "green", "value": 0.5 }
            ]
          }
        },
        "overrides": []
