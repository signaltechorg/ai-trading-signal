# TradeClaw Configuration — copy this to .env and customize
# ⚠️  Variables marked REQUIRED must be set before `docker compose up`

# ---------------------------------------------------------------------------
# Database (REQUIRED)
# ---------------------------------------------------------------------------
DB_NAME=tradeclaw
DB_USER=tradeclaw
DB_PASSWORD=                          # REQUIRED — generate with: openssl rand -hex 16

# ---------------------------------------------------------------------------
# App (REQUIRED)
# ---------------------------------------------------------------------------
APP_PORT=3000
APP_URL=http://localhost:3000         # Set to your public URL in production
USER_SESSION_SECRET=                  # REQUIRED for the web app — generate with: openssl rand -hex 32
                                      # Signs session cookies, OAuth state, Telegram link tokens.
                                      # Without it every sign-in/session op 500s (lib/user-session.ts).
AUTH_SECRET=                          # REQUIRED for the ws-server — generate with: openssl rand -hex 32
                                      # Consumed by apps/ws-server (middleware/auth.ts), not the web app.

# ---------------------------------------------------------------------------
# WebSocket Server (real-time price streaming)
# ---------------------------------------------------------------------------
WS_SERVER_PORT=4000
NEXT_PUBLIC_WS_URL=                   # Auto-detected from browser if blank
                                      # Set to wss://your-domain:4000 in production

# ---------------------------------------------------------------------------
# Market Data Hub (optional — hosted TradeClaw only)
# ---------------------------------------------------------------------------
# Pre-cached market data via Redis. Reduces upstream API calls and improves
# reliability. Docker / self-hosted users: leave blank to use free APIs.
MARKET_DATA_HUB_URL=

# ---------------------------------------------------------------------------
# Redis
# ---------------------------------------------------------------------------
REDIS_URL=redis://redis:6379

# ---------------------------------------------------------------------------
# Scanner
# ---------------------------------------------------------------------------
SCAN_INTERVAL=60
SCAN_INSTRUMENTS=all

# ---------------------------------------------------------------------------
# Telegram (optional — for bot alerts)
# ---------------------------------------------------------------------------
TELEGRAM_BOT_TOKEN=
TELEGRAM_WEBHOOK_URL=
# Channel / group IDs (use negative numbers for groups)
TELEGRAM_FREE_CHANNEL_ID=
TELEGRAM_PRO_GROUP_ID=
TELEGRAM_ELITE_GROUP_ID=

# Private channel invite links for paying subscribers (t.me/joinchat/... or t.me/+...)
TELEGRAM_PRO_CHANNEL_INVITE=
TELEGRAM_ELITE_CHANNEL_INVITE=

# ---------------------------------------------------------------------------
# Discord (optional — for Discord bot signals)
# ---------------------------------------------------------------------------
DISCORD_BOT_TOKEN=                    # Bot token from https://discord.com/developers (gateway bot)
DISCORD_CLIENT_ID=                    # Application ID (for invite link)
# Webhook-first signal broadcasting (issue #38): when set, the /api/cron/telegram
# job posts TradeClaw's own free-tier signals to this Discord channel webhook as
# color-coded embeds, deduped per (pair, direction) per 2h window. Independent of
# the gateway bot above and of Telegram. Create one in Server Settings → Integrations.
DISCORD_WEBHOOK_URL=                  # e.g. https://discord.com/api/webhooks/<id>/<token>

# ---------------------------------------------------------------------------
# Email notifications (optional, for the "email" alert channel)
# Without these the alert dispatcher logs email rows as failed deliveries
# rather than silently dropping the user's preference.
#
# Pick a provider:
#   EMAIL_PROVIDER=resend     (default) — uses RESEND_API_KEY
#   EMAIL_PROVIDER=sendgrid             — uses SENDGRID_API_KEY
#   EMAIL_PROVIDER=smtp                 — uses SMTP_HOST / SMTP_PORT / SMTP_USER / SMTP_PASS
#                                         (requires `npm install nodemailer @types/nodemailer`)
# ---------------------------------------------------------------------------
EMAIL_PROVIDER=resend
RESEND_API_KEY=                       # Format: re_xxxxxxxx
RESEND_FROM_EMAIL=                    # e.g. "TradeClaw <signals@tradeclaw.win>" — domain must be Resend-verified

# SendGrid (when EMAIL_PROVIDER=sendgrid)
SENDGRID_API_KEY=                     # Format: SG.xxxxxx

# SMTP (when EMAIL_PROVIDER=smtp) — e.g. Gmail App Password, Postfix, Mailgun SMTP
SMTP_HOST=                            # e.g. smtp.gmail.com
SMTP_PORT=587                         # 587 for STARTTLS, 465 for implicit TLS
SMTP_USER=                            # e.g. you@gmail.com
SMTP_PASS=                            # SMTP password / app password

# Daily digest email recipients (optional) — comma-separated. When set, the
# /api/cron/daily-digest job emails today's top signals via EMAIL_PROVIDER above,
# independently of Telegram. Leave blank to disable the digest email.
EMAIL_TO=                             # e.g. me@example.com, team@example.com

# ---------------------------------------------------------------------------
# Stripe (optional — for paid tiers)
# ---------------------------------------------------------------------------
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRO_MONTHLY_PRICE_ID=
STRIPE_PRO_ANNUAL_PRICE_ID=
STRIPE_ELITE_MONTHLY_PRICE_ID=
STRIPE_ELITE_ANNUAL_PRICE_ID=
NEXT_PUBLIC_STRIPE_PRO_MONTHLY_PRICE_ID=
NEXT_PUBLIC_STRIPE_ELITE_MONTHLY_PRICE_ID=

# ---------------------------------------------------------------------------
# Upstash Redis (optional — for API rate limiting on Elite tier)
# ---------------------------------------------------------------------------
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# ---------------------------------------------------------------------------
# Cron / GitHub Action (used by .github/workflows/signal-log.yml)
# ---------------------------------------------------------------------------
CRON_SECRET=                          # Shared secret for the /api/cron/signals endpoint
                                      # Set as a GitHub Actions secret (CRON_SECRET) and
                                      # in your deployed app's environment variables
                                      # Generate with: openssl rand -hex 32

# ---------------------------------------------------------------------------
# Railway PostgreSQL (signal storage — replaces JSON files)
# ---------------------------------------------------------------------------
DATABASE_URL=                         # Railway Postgres connection string
                                      # Format: postgresql://user:pass@host:port/dbname
                                      # The signal engine + Next.js app both use this
WRITE_JSON_FALLBACK=true              # Also write signals-live.json (for debugging)

# ---------------------------------------------------------------------------
# Signal Engine Preset (optional — controls strategy logic)
# ---------------------------------------------------------------------------
# Active signal engine preset: classic | regime-aware | hmm-top3 | vwap-ema-bb | full-risk
# Default: hmm-top3 (current production)
SIGNAL_ENGINE_PRESET=hmm-top3
